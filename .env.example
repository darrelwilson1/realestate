# Copy to .env.local and fill in your value.

# MongoDB Atlas connection string. Format:
#   mongodb+srv://USER:URL-ENCODED-PASSWORD@CLUSTER.mongodb.net/DBNAME?retryWrites=true&w=majority
# Encode special characters in the password (e.g. ! → %21).
# The DBNAME at the end is required so collections land in a named database
# rather than the default `test`.
MONGODB_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/darrels?retryWrites=true&w=majority
