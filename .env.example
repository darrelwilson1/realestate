# Copy to .env.local and fill in values from Supabase project Settings → API.

# Public Supabase project URL — safe to expose in browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable (anon) key — safe to expose in browser. RLS still enforced.
# Newer projects use sb_publishable_... format; older use a JWT-style anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
