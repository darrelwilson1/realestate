# Copy to .env.local and fill in your values.

# Supabase project URL — found in: Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase publishable (anon) key — safe to ship to the browser.
# Use the new sb_publishable_* format from Supabase dashboard → Project Settings → API keys.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
