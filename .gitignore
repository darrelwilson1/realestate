# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but keep the template so contributors know which vars to set.
!.env.example
# Production env is checked in — only contains NEXT_PUBLIC_* keys that ship to
# the browser anyway and are gated by Supabase RLS policies. Never put a
# service-role key or other secret in here.
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code — keep launch.json shareable, but ignore personal/local settings
.claude/settings.local.json
.claude/worktrees/
